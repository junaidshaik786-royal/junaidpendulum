<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Junaid's Pendulum Wave | Harmonic Synchronization</title>
    <meta name="description" content="Experience the mesmerizing pendulum wave with harmonic sounds by Junaid Shaik">
    <meta name="author" content="Junaid Shaik">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-dark: #020208;
            --bg-panel: rgba(8, 12, 20, 0.92);
            --accent-cyan: #00f0ff;
            --accent-magenta: #ff00ff;
            --accent-gold: #ffd700;
            --accent-green: #00ff88;
            --text-primary: #e0f4ff;
            --text-secondary: #7a9bb5;
            --border-glow: rgba(0, 240, 255, 0.3);
            --grid-color: rgba(0, 240, 255, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow: hidden;
            background: var(--bg-dark);
            font-family: 'Rajdhani', sans-serif;
            color: var(--text-primary);
            cursor: default;
        }

        /* Background Effects */
        #bgCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.7;
        }

        #mainCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* Header */
        .header {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            z-index: 100;
        }

        .header h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: 8px;
            color: var(--accent-cyan);
            text-shadow: 
                0 0 10px var(--accent-cyan),
                0 0 20px var(--accent-cyan),
                0 0 40px rgba(0, 240, 255, 0.5);
            text-transform: uppercase;
        }

        .header .subtitle {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-secondary);
            letter-spacing: 4px;
            margin-top: 5px;
        }

        /* Attribution */
        .attribution {
            position: fixed;
            top: 20px;
            left: 20px;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.7rem;
            color: var(--accent-gold);
            z-index: 100;
            padding: 8px 15px;
            background: var(--bg-panel);
            border: 1px solid var(--accent-gold);
            border-radius: 4px;
            text-shadow: 0 0 10px var(--accent-gold);
        }

        /* Main Control Panel */
        .main-panel {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-panel);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-glow);
            border-radius: 12px;
            padding: 20px 30px;
            z-index: 100;
            display: flex;
            gap: 30px;
            align-items: center;
            box-shadow: 
                0 0 30px rgba(0, 240, 255, 0.1),
                inset 0 0 30px rgba(0, 240, 255, 0.02);
        }

        .control-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .control-label {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-secondary);
        }

        .control-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--accent-cyan);
            text-shadow: 0 0 8px var(--accent-cyan);
        }

        /* Sliders */
        input[type="range"] {
            -webkit-appearance: none;
            width: 120px;
            height: 6px;
            background: linear-gradient(90deg, var(--accent-cyan), var(--accent-magenta));
            border-radius: 3px;
            outline: none;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

        input[type="range"]:hover {
            opacity: 1;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            background: var(--bg-dark);
            border: 2px solid var(--accent-cyan);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 15px var(--accent-cyan);
            transition: all 0.2s;
        }

        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
            box-shadow: 0 0 25px var(--accent-cyan);
        }

        /* Buttons */
        .btn {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 12px 25px;
            border: 2px solid var(--accent-cyan);
            background: transparent;
            color: var(--accent-cyan);
            border-radius: 6px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 3px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.3), transparent);
            transition: left 0.5s;
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn:hover {
            background: rgba(0, 240, 255, 0.15);
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.4);
            text-shadow: 0 0 10px var(--accent-cyan);
        }

        .btn.playing {
            border-color: var(--accent-magenta);
            color: var(--accent-magenta);
        }

        .btn.playing:hover {
            background: rgba(255, 0, 255, 0.15);
            box-shadow: 0 0 30px rgba(255, 0, 255, 0.4);
            text-shadow: 0 0 10px var(--accent-magenta);
        }

        /* Audio Toggle */
        .audio-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 1.3rem;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .audio-btn.muted {
            border-color: var(--text-secondary);
            color: var(--text-secondary);
        }

        /* Stats Display */
        .stats-display {
            position: fixed;
            top: 100px;
            right: 30px;
            background: var(--bg-panel);
            backdrop-filter: blur(15px);
            border: 1px solid var(--border-glow);
            border-radius: 8px;
            padding: 15px 20px;
            z-index: 100;
            min-width: 180px;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid rgba(0, 240, 255, 0.1);
        }

        .stat-row:last-child {
            border-bottom: none;
        }

        .stat-label {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.7rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--accent-cyan);
            text-shadow: 0 0 8px var(--accent-cyan);
        }

        .stat-value.gold { color: var(--accent-gold); text-shadow: 0 0 8px var(--accent-gold); }
        .stat-value.green { color: var(--accent-green); text-shadow: 0 0 8px var(--accent-green); }
        .stat-value.magenta { color: var(--accent-magenta); text-shadow: 0 0 8px var(--accent-magenta); }

        /* Sync Bar */
        .sync-container {
            margin-top: 10px;
        }

        .sync-bar-bg {
            width: 100%;
            height: 8px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid var(--border-glow);
        }

        .sync-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--accent-magenta), var(--accent-cyan), var(--accent-green));
            transition: width 0.1s;
            box-shadow: 0 0 15px var(--accent-cyan);
        }

        .sync-text {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem;
            text-align: center;
            margin-top: 5px;
            color: var(--text-secondary);
        }

        .sync-text.synced {
            color: var(--accent-green);
            text-shadow: 0 0 10px var(--accent-green);
            animation: pulse-glow 0.5s infinite alternate;
        }

        @keyframes pulse-glow {
            from { opacity: 0.7; }
            to { opacity: 1; }
        }

        /* Wave Visualizer */
        .wave-viz {
            position: fixed;
            bottom: 140px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-panel);
            border: 1px solid var(--border-glow);
            border-radius: 8px;
            padding: 10px;
            z-index: 100;
        }

        #waveCanvas {
            display: block;
            border-radius: 4px;
        }

        /* Instructions */
        .instructions {
            position: fixed;
            bottom: 200px;
            left: 50%;
            transform: translateX(-50%);
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.7rem;
            color: var(--text-secondary);
            opacity: 0.5;
            z-index: 50;
        }

        @media (max-width: 900px) {
            .main-panel {
                flex-wrap: wrap;
                justify-content: center;
                width: 90%;
                padding: 15px;
                gap: 15px;
            }
            
            .stats-display {
                top: auto;
                bottom: 350px;
                right: 10px;
                min-width: 140px;
                padding: 10px;
            }
            
            .header h1 {
                font-size: 1.2rem;
                letter-spacing: 4px;
            }
        }
    </style>
</head>
<body>

    <canvas id="bgCanvas"></canvas>
    <canvas id="mainCanvas"></canvas>

    <div class="header">
        <h1>Pendulum Wave</h1>
        <div class="subtitle">// Harmonic Synchronization System //</div>
    </div>

    <div class="attribution">
        ⚡ Created by Junaid Shaik
    </div>

    <!-- Stats Display -->
    <div class="stats-display">
        <div class="stat-row">
            <span class="stat-label">Time</span>
            <span class="stat-value" id="timeVal">0.00s</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Bounces/s</span>
            <span class="stat-value gold" id="bounceVal">0</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Notes/s</span>
            <span class="stat-value magenta" id="notesVal">0</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Status</span>
            <span class="stat-value green" id="statusVal">Ready</span>
        </div>
        <div class="sync-container">
            <div class="sync-bar-bg">
                <div class="sync-bar-fill" id="syncBar"></div>
            </div>
            <div class="sync-text" id="syncText">0% Synchronized</div>
        </div>
    </div>

    <!-- Wave Visualizer -->
    <div class="wave-viz">
        <canvas id="waveCanvas" width="400" height="60"></canvas>
    </div>

    <div class="instructions">▶ Press Play to Start | 🔊 Headphones Recommended</div>

    <!-- Main Controls -->
    <div class="main-panel">
        <div class="control-section">
            <span class="control-label">Pendulums</span>
            <input type="range" id="countSlider" min="15" max="50" value="30">
            <span class="control-value" id="countVal">30</span>
        </div>
        <div class="control-section">
            <span class="control-label">Speed</span>
            <input type="range" id="speedSlider" min="1" max="10" step="0.5" value="3">
            <span class="control-value" id="speedVal">3x</span>
        </div>
        <div class="control-section">
            <span class="control-label">Base Note</span>
            <input type="range" id="noteSlider" min="100" max="500" step="10" value="220">
            <span class="control-value" id="noteVal">A3</span>
        </div>
        <div class="control-section">
            <span class="control-label">Volume</span>
            <input type="range" id="volSlider" min="0" max="1" step="0.05" value="0.4">
            <span class="control-value" id="volVal">40%</span>
        </div>
        <button class="btn" id="playBtn">▶ Play</button>
        <button class="btn" id="resetBtn">↺ Reset</button>
        <button class="btn audio-btn" id="audioBtn">🔊</button>
    </div>

    <script>
        // ===============================
        // PENDULUM WAVE SIMULATION
        // Created by Junaid Shaik
        // ===============================

        const mainCanvas = document.getElementById('mainCanvas');
        const ctx = mainCanvas.getContext('2d');
        const bgCanvas = document.getElementById('bgCanvas');
        const bgCtx = bgCanvas.getContext('2d');
        const waveCanvas = document.getElementById('waveCanvas');
        const waveCtx = waveCanvas.getContext('2d');

        // Stats Elements
        const timeVal = document.getElementById('timeVal');
        const bounceVal = document.getElementById('bounceVal');
        const notesVal = document.getElementById('notesVal');
        const statusVal = document.getElementById('statusVal');
        const syncBar = document.getElementById('syncBar');
        const syncText = document.getElementById('syncText');

        // Controls
        const countSlider = document.getElementById('countSlider');
        const speedSlider = document.getElementById('speedSlider');
        const noteSlider = document.getElementById('noteSlider');
        const volSlider = document.getElementById('volSlider');
        const playBtn = document.getElementById('playBtn');
        const resetBtn = document.getElementById('resetBtn');
        const audioBtn = document.getElementById('audioBtn');

        // Display values
        const countVal = document.getElementById('countVal');
        const speedVal = document.getElementById('speedVal');
        const noteVal = document.getElementById('noteVal');
        const volVal = document.getElementById('volVal');

        // ===============================
        // AUDIO ENGINE - Music Notes
        // ===============================
        
        let audioCtx = null;
        let isPlaying = false;
        let isAudioOn = true;
        let volume = 0.4;
        let baseNote = 220;
        let bounceCount = 0;
        let noteCount = 0;
        let bounceBuffer = [];
        let noteBuffer = [];

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        // Convert frequency to note name
        function freqToNote(freq) {
            const notes = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B'];
            const noteNum = 12 * (Math.log2(freq / 440)) + 49;
            const note = Math.round(noteNum);
            const octave = Math.floor(note / 12) - 1;
            const noteName = notes[note % 12];
            return noteName + octave;
        }

        // Create metallic chime sound (like glockenspiel/metallic rod)
        function playChime(freq, velocity = 1) {
            if (!isAudioOn || !audioCtx) return;

            const now = audioCtx.currentTime;
            
            // Create oscillators for rich harmonic sound
            const osc1 = audioCtx.createOscillator();
            const osc2 = audioCtx.createOscillator();
            const osc3 = audioCtx.createOscillator();
            
            // Gain envelopes
            const gain1 = audioCtx.createGain();
            const gain2 = audioCtx.createGain();
            const gain3 = audioCtx.createGain();
            
            // Master gain
            const masterGain = audioCtx.createGain();
            
            // Set frequencies - harmonic series (like metallic rod)
            osc1.frequency.value = freq;
            osc2.frequency.value = freq * 2.756; // Inharmonic partial
            osc3.frequency.value = freq * 5.404; // Higher partial
            
            // Oscillator types - sharp and metallic
            osc1.type = 'sine';
            osc2.type = 'triangle';
            osc3.type = 'sine';
            
            // Attack and decay envelopes for metallic sound
            const attackTime = 0.005;
            const decayTime = 0.3 + (0.5 / (freq / 200)); // Lower notes last longer
            
            // Oscillator 1
            gain1.gain.setValueAtTime(0, now);
            gain1.gain.linearRampToValueAtTime(volume * velocity * 0.6, now + attackTime);
            gain1.gain.exponentialRampToValueAtTime(0.001, now + decayTime);
            
            // Oscillator 2
            gain2.gain.setValueAtTime(0, now);
            gain2.gain.linearRampToValueAtTime(volume * velocity * 0.3, now + attackTime);
            gain2.gain.exponentialRampToValueAtTime(0.001, now + decayTime * 0.5);
            
            // Oscillator 3
            gain3.gain.setValueAtTime(0, now);
            gain3.gain.linearRampToValueAtTime(volume * velocity * 0.15, now + attackTime);
            gain3.gain.exponentialRampToValueAtTime(0.001, now + decayTime * 0.3);
            
            // Master volume
            masterGain.gain.value = 0.7;
            
            // Connect
            osc1.connect(gain1);
            osc2.connect(gain2);
            osc3.connect(gain3);
            
            gain1.connect(masterGain);
            gain2.connect(masterGain);
            gain3.connect(masterGain);
            
            masterGain.connect(audioCtx.destination);
            
            // Start and stop
            osc1.start(now);
            osc2.start(now);
            osc3.start(now);
            
            osc1.stop(now + decayTime + 0.1);
            osc2.stop(now + decayTime + 0.1);
            osc3.stop(now + decayTime + 0.1);
        }

        // Play start fanfare
        function playStartChord() {
            if (!isAudioOn || !audioCtx) return;
            
            const notes = [baseNote, baseNote * 1.25, baseNote * 1.5, baseNote * 2];
            notes.forEach((freq, i) => {
                setTimeout(() => playChime(freq, 0.5), i * 80);
            });
        }

        // Play sync success chord
        function playSyncChord() {
            if (!isAudioOn || !audioCtx) return;
            
            const notes = [baseNote * 2, baseNote * 2.5, baseNote * 3, baseNote * 4];
            notes.forEach((freq, i) => {
                setTimeout(() => playChime(freq, 0.7), i * 100);
            });
        }

        // ===============================
        // SIMULATION ENGINE
        // ===============================

        let pendulums = [];
        let time = 0;
        let settings = {
            count: 30,
            speed: 3
        };

        let waveHistory = [];
        let wasSynced = false;

        // Neon color palette
        const colors = [
            '#00f0ff', '#00d4ff', '#00b8ff', '#009cff', '#0080ff',
            '#ff00ff', '#ff00e0', '#ff00c0', '#ff00a0', '#ff0080',
            '#00ff88', '#00ff66', '#88ff00', '#ccff00', '#ffdd00',
            '#ff8800', '#ff4400', '#ff0044', '#ff0066', '#00ffee',
            '#00ddff', '#66ffff', '#aaffff', '#ff66ff', '#ff99ff',
            '#cc99ff', '#9966ff', '#6600ff', '#9900ff', '#cc00ff'
        ];

        function resize() {
            mainCanvas.width = window.innerWidth;
            mainCanvas.height = window.innerHeight;
            bgCanvas.width = window.innerWidth;
            bgCanvas.height = window.innerHeight;
            initPendulums();
        }

        function initPendulums() {
            pendulums = [];
            waveHistory = [];
            const count = settings.count;
            
            // Calculate frequencies for perfect sync
            // Each pendulum has slightly different frequency
            // They all sync at LCM point
            
            for (let i = 0; i < count; i++) {
                const pivotX = (mainCanvas.width / (count + 1)) * (i + 1);
                const pivotY = 80;
                const lenRatio = (mainCanvas.height - 160) / count;
                const length = (i + 1) * lenRatio;
                
                // Frequency calculation for wave effect
                // Longer pendulums swing slower
                const baseFreq = 1;
                const freqStep = 0.002;
                const frequency = baseFreq + (i * freqStep);
                
                // Musical note for this pendulum
                // Each pendulum plays a note based on its position
                const noteRatio = Math.pow(2, i / 12); // Half steps in chromatic scale
                const noteFreq = baseNote * noteRatio;
                
                pendulums.push({
                    pivotX,
                    pivotY,
                    length,
                    frequency,
                    noteFreq,
                    noteName: freqToNote(noteFreq),
                    amplitude: 0.5,
                    color: colors[i % colors.length],
                    currentAngle: 0,
                    prevAngle: 0,
                    id: i,
                    hasBounced: false
                });
            }
        }

        function update() {
            if (!isPlaying) {
                // Still draw when paused
                drawBg();
                draw();
                drawWave();
                requestAnimationFrame(update);
                return;
            }

            time += settings.speed * 0.05;

            bounceCount = 0;
            noteCount = 0;

            let syncedCount = 0;

            pendulums.forEach(p => {
                p.prevAngle = p.currentAngle;
                p.currentAngle = p.amplitude * Math.sin(time * p.frequency);
                
                // Detect crossing center (for bounce sound)
                // Crossing from negative to positive or vice versa
                const crossedPositive = (p.prevAngle < 0 && p.currentAngle >= 0);
                const crossedNegative = (p.prevAngle > 0 && p.currentAngle <= 0);
                const crossedCenter = crossedPositive || crossedNegative;
                
                if (crossedCenter && time > 1) {
                    bounceCount++;
                    
                    // Only play sound every few bounces to avoid cacophony
                    // Play based on pendulum index pattern
                    if (p.id % 3 === 0 || syncedCount > pendulums.length * 0.8) {
                        const velocity = 0.3 + (p.id / pendulums.length) * 0.7;
                        playChime(p.noteFreq, velocity);
                        noteCount++;
                    }
                }
                
                // Check sync
                if (Math.abs(p.currentAngle) < 0.03) {
                    syncedCount++;
                }
                
                // Calculate bob position
                p.bobX = p.pivotX + p.length * Math.sin(p.currentAngle);
                p.bobY = p.pivotY + p.length * Math.cos(p.currentAngle);
            });

            // Sync celebration
            if (syncedCount === pendulums.length && !wasSynced) {
                wasSynced = true;
                playSyncChord();
                statusVal.textContent = 'SYNCED!';
            } else if (syncedCount < pendulums.length) {
                wasSynced = false;
                statusVal.textContent = 'Running';
            }

            drawBg();
            draw();
            drawWave();
            updateStats(syncedCount);
            
            requestAnimationFrame(update);
        }

        // ===============================
        // DRAWING FUNCTIONS
        // ===============================

        // Background grid and particles
        let particles = [];
        function initParticles() {
            particles = [];
            for (let i = 0; i < 50; i++) {
                particles.push({
                    x: Math.random() * bgCanvas.width,
                    y: Math.random() * bgCanvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    size: Math.random() * 2 + 1,
                    opacity: Math.random() * 0.3 + 0.1
                });
            }
        }

        function drawBg() {
            // Dark gradient background
            const grad = bgCtx.createRadialGradient(
                bgCanvas.width / 2, bgCanvas.height / 2, 0,
                bgCanvas.width / 2, bgCanvas.height / 2, bgCanvas.width * 0.7
            );
            grad.addColorStop(0, 'rgba(10, 15, 30, 1)');
            grad.addColorStop(1, 'rgba(2, 2, 8, 1)');
            bgCtx.fillStyle = grad;
            bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);

            // Subtle grid
            bgCtx.strokeStyle = 'rgba(0, 240, 255, 0.03)';
            bgCtx.lineWidth = 1;
            const gridSize = 60;
            
            for (let x = 0; x < bgCanvas.width; x += gridSize) {
                bgCtx.beginPath();
                bgCtx.moveTo(x, 0);
                bgCtx.lineTo(x, bgCanvas.height);
                bgCtx.stroke();
            }
            for (let y = 0; y < bgCanvas.height; y += gridSize) {
                bgCtx.beginPath();
                bgCtx.moveTo(0, y);
                bgCtx.lineTo(bgCanvas.width, y);
                bgCtx.stroke();
            }

            // Floating particles
            particles.forEach(p => {
                p.x += p.vx;
                p.y += p.vy;
                
                if (p.x < 0) p.x = bgCanvas.width;
                if (p.x > bgCanvas.width) p.x = 0;
                if (p.y < 0) p.y = bgCanvas.height;
                if (p.y > bgCanvas.height) p.y = 0;
                
                bgCtx.beginPath();
                bgCtx.fillStyle = `rgba(0, 240, 255, ${p.opacity})`;
                bgCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                bgCtx.fill();
            });
        }

        function draw() {
            // Clear main canvas
            ctx.clearRect(0, 0, mainCanvas.width, mainCanvas.height);

            // Draw pendulums
            ctx.lineWidth = 2;
            
            pendulums.forEach((p, index) => {
                if (p.amplitude === 0) return;

                // Glow effect
                ctx.shadowBlur = 15;
                ctx.shadowColor = p.color;

                // String/rod
                const grad = ctx.createLinearGradient(p.pivotX, p.pivotY, p.bobX, p.bobY);
                grad.addColorStop(0, p.color);
                grad.addColorStop(1, 'rgba(255, 255, 255, 0.6)');
                
                ctx.beginPath();
                ctx.strokeStyle = grad;
                ctx.moveTo(p.pivotX, p.pivotY);
                ctx.lineTo(p.bobX, p.bobY);
                ctx.stroke();

                // Pivot point
                ctx.beginPath();
                ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
                ctx.arc(p.pivotX, p.pivotY, 5, 0, Math.PI * 2);
                ctx.fill();

                // Bob with glow
                ctx.beginPath();
                ctx.fillStyle = p.color;
                ctx.arc(p.bobX, p.bobY, 5, 0, Math.PI * 2);
                ctx.fill();

                // Extra glow layer
                ctx.globalAlpha = 0.4;
                ctx.beginPath();
                ctx.arc(p.bobX, p.bobY, 10, 0, Math.PI * 2);
                ctx.fill();
                ctx.globalAlpha = 1;
            });

            ctx.shadowBlur = 0;

            // Center reference line
            ctx.beginPath();
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
            ctx.setLineDash([5, 10]);
            ctx.moveTo(50, mainCanvas.height / 2);
            ctx.lineTo(mainCanvas.width - 50, mainCanvas.height / 2);
            ctx.stroke();
            ctx.setLineDash([]);
        }

        function drawWave() {
            const w = waveCanvas.width;
            const h = waveCanvas.height;
            
            waveCtx.fillStyle = 'rgba(0, 0, 0, 0.3)';
            waveCtx.fillRect(0, 0, w, h);
            
            waveHistory.push(pendulums.map(p => p.currentAngle));
            if (waveHistory.length > w) waveHistory.shift();

            // Center line
            waveCtx.strokeStyle = 'rgba(0, 240, 255, 0.2)';
            waveCtx.beginPath();
            waveCtx.moveTo(0, h / 2);
            waveCtx.lineTo(w, h / 2);
            waveCtx.stroke();

            // Draw wave traces
            const maxTraces = Math.min(8, pendulums.length);
            for (let i = 0; i < maxTraces; i++) {
                const p = pendulums[i];
                waveCtx.beginPath();
                waveCtx.strokeStyle = p.color;
                waveCtx.lineWidth = 1.5;
                waveCtx.globalAlpha = 0.8;
                
                for (let x = 0; x < waveHistory.length; x++) {
                    const y = h / 2 - (waveHistory[x][i] / 0.5) * (h / 2 - 5);
                    if (x === 0) waveCtx.moveTo(x, y);
                    else waveCtx.lineTo(x, y);
                }
                waveCtx.stroke();
            }
            waveCtx.globalAlpha = 1;
        }

        function updateStats(syncedCount) {
            const syncPercent = Math.round((syncedCount / pendulums.length) * 100);
            
            timeVal.textContent = (time / 10).toFixed(2) + 's';
            bounceVal.textContent = bounceCount;
            notesVal.textContent = noteCount;
            syncBar.style.width = syncPercent + '%';
            syncText.textContent = syncPercent + '% Synchronized';
            
            if (syncPercent === 100) {
                syncText.textContent = '🎉 FULLY SYNCHRONIZED!';
                syncText.classList.add('synced');
            } else {
                syncText.classList.remove('synced');
            }
        }

        // ===============================
        // EVENT LISTENERS
        // ===============================

        countSlider.addEventListener('input', (e) => {
            settings.count = parseInt(e.target.value);
            countVal.textContent = settings.count;
            initPendulums();
        });

        speedSlider.addEventListener('input', (e) => {
            settings.speed = parseFloat(e.target.value);
            speedVal.textContent = settings.speed + 'x';
        });

        noteSlider.addEventListener('input', (e) => {
            baseNote = parseInt(e.target.value);
            noteVal.textContent = freqToNote(baseNote);
            initPendulums(); // Update note assignments
        });

        volSlider.addEventListener('input', (e) => {
            volume = parseFloat(e.target.value);
            volVal.textContent = Math.round(volume * 100) + '%';
        });

        playBtn.addEventListener('click', () => {
            initAudio();
            isPlaying = !isPlaying;
            
            if (isPlaying) {
                playBtn.textContent = '⏸ Pause';
                playBtn.classList.add('playing');
                playStartChord();
            } else {
                playBtn.textContent = '▶ Play';
                playBtn.classList.remove('playing');
            }
        });

        resetBtn.addEventListener('click', () => {
            time = 0;
            waveHistory = [];
            wasSynced = false;
            statusVal.textContent = 'Ready';
            initPendulums();
            if (isPlaying) playStartChord();
        });

        audioBtn.addEventListener('click', () => {
            initAudio();
            isAudioOn = !isAudioOn;
            audioBtn.textContent = isAudioOn ? '🔊' : '🔇';
            audioBtn.classList.toggle('muted', !isAudioOn);
        });

        window.addEventListener('resize', () => {
            resize();
            initParticles();
        });

        // Initialize
        resize();
        initParticles();
        update();
    </script>
</body>
</html>
